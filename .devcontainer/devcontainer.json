{
  "name": "Copy Fail – CVE-2026-31431 Lab",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "runArgs": [
    "--privileged",
    "--device=/dev/kvm"
  ],
  "capAdd": ["SYS_ADMIN", "NET_ADMIN"],
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspaces/copy-fail-challenge,type=bind,consistency=cached"
  ],
  "remoteEnv": {
    "KERNEL_VERSION": "6.12",
    "KERNEL_TAG": "v6.12",
    "VULN_COMMIT": "72548b093ee3",
    "FIX_COMMIT": "a664bf3d603d"
  },
  "postCreateCommand": "bash /workspaces/copy-fail-challenge/scripts/00_welcome.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "mhutchie.git-graph",
        "eamodio.gitlens"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "git.autofetch": true
      }
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  }
}
